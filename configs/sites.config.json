{
  "sites": [
    {
      "name": "sw-cargo-auto-crawling",
      "baseUrl": "https://preview.portal.swcargo.lk",
      "authFile": "auth/sw-cargo-auth.json",

      "autoLogin": {
        "loginUrl": "https://preview.portal.swcargo.lk/login",
        "usernameSelector": "#email",
        "passwordSelector": "#password",
        "submitSelector": "button[type='submit']",
        "successSelector": "nav, .sidebar, [class*='dashboard'], [class*='layout']"
      },

      "autoCrawl": {
        "enabled": true,
        "maxPages": 50,
        "maxDepth": 5,
        "excludePatterns": ["/admin", "/logout", "/settings"],
        "delayMs": 500,
        "respectRobotsTxt": true,
        "minContentLength": 100,
        "prioritizeByContent": true
      }
    }
  ]
}
