{
  "sites": [
    {
      "name": "sw-cargo-auto-crawling",
      "baseUrl": "https://preview.portal.swcargo.lk",
      "authFile": "auth/sw-cargo-auth.json",
      "autoCrawl": {
        "enabled": true,
        "maxPages": 50,
        "maxDepth": 10,
        "excludePatterns": ["/admin", "/logout", "/settings"],
        "delayMs": 500,
        "respectRobotsTxt": true,
        "minContentLength": 100,
        "prioritizeByContent": true
      }
    }
  ]
}
